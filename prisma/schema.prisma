// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id               String   @id @default(cuid())
  title            String
  category         String
  videoUrl         String?
  thumbnailUrl     String?
  clientName       String?
  shortDescription String?
  results          String?
  contentType      String   @default("video")
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  imageUrl  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id         String   @id @default(cuid())
  clientName String
  role       String?
  company    String?
  quote      String
  videoUrl   String?
  imageUrl   String?
  // Social Media Stats (Optional)
  ytSubscribers  String?
  ytViews        String?
  igFollowers    String?
  fbFollowers    String?
  tiktokFollowers String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Service {
  id             String   @id @default(cuid())
  title          String
  description    String
  iconIdentifier String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProcessStep {
  id             String   @id @default(cuid())
  number         String
  title          String
  description    String
  iconIdentifier String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TrustedBrand {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id                   String  @id @default("global")

  // Hero Section
  heroSubtitle         String?
  heroTitle            String?
  heroTitleHighlight   String?
  heroDescription      String?
  heroVideoUrl         String?
  heroPosterUrl        String?

  // Logo
  logoLightUrl         String?
  logoDarkUrl          String?
  faviconUrl           String?

  // Contact
  phone                String?
  email                String?
  whatsappNumber       String?
  calendlyUrl          String?
  address              String?
  city                 String?

  // Social Links
  instagramUrl         String?
  twitterUrl           String?
  linkedinUrl          String?
  youtubeUrl           String?

  // Team Carousel
  teamCarouselDistance  Int     @default(380)

  // Footer
  footerTagline        String?
  copyrightText        String?

  // SEO
  siteTitle            String?
  siteDescription      String?
  
  // Brands
  trustedBrandsGrayscale Boolean @default(true)
  trustedBrandsMarqueeSpeed Int @default(40)
  
  // Policies
  privacyPolicy        String?
  termsOfService       String?
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
